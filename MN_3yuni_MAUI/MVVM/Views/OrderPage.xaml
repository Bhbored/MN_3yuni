<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MN_3yuni_MAUI.MVVM.Views.OrderPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MN_3yuni_MAUI.Controls"
    BackgroundColor="{StaticResource BackgroundGray}">

    <AbsoluteLayout>
        <Grid
            Margin="0,0,0,76"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>


            <VerticalStackLayout
                Grid.Row="0"
                Margin="20,40,20,16"
                Spacing="16">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="35">
                    <Border
                        Background="{StaticResource Brush.CardBg}"
                        HorizontalOptions="Center"
                        Shadow="{StaticResource Sh.PurpleLg}"
                        StrokeShape="RoundRectangle 20"
                        StyleClass="pill-secondary"
                        VerticalOptions="Center">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Path
                                Margin="0,0,0,5"
                                Data="M19,7c0-1.1-0.9-2-2-2h-3v2h3v2.65L13.52,14H10V9H6c-2.21,0-4,1.79-4,4v3h2c0,1.66,1.34,3,3,3s3-1.34,3-3h4.48L19,10.35V7z M5,6h5v2h-5z M19,13c-1.66,0-3,1.34-3,3s1.34,3,3,3s3-1.34,3-3s-1.34-3-3-3z M19,17c-0.55,0-1-0.45-1-1s0.45-1,1-1s1,0.45,1,1s-0.45,1-1,1z"
                                Fill="{StaticResource Primary}"
                                HeightRequest="25"
                                WidthRequest="25">
                                <Path.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsUpcomingSelected}"
                                        TargetType="Path"
                                        Value="False">
                                        <Setter Property="Fill" Value="{StaticResource Gray200}" />
                                        <Setter Property="HeightRequest" Value="20" />
                                        <Setter Property="WidthRequest" Value="20" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding IsUpcomingSelected}"
                                        TargetType="Path"
                                        Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Primary}" />
                                        <Setter Property="HeightRequest" Value="25" />
                                        <Setter Property="WidthRequest" Value="25" />
                                    </DataTrigger>
                                </Path.Triggers>
                            </Path>
                            <Label
                                Grid.Column="1"
                                StyleClass="pill-secondary-text"
                                Text="Upcoming">
                                <Label.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsUpcomingSelected}"
                                        TargetType="Label"
                                        Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource PrimaryDark}" />
                                        <Setter Property="FontFamily" Value="poppinbold" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding IsUpcomingSelected}"
                                        TargetType="Label"
                                        Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource Gray200}" />
                                        <Setter Property="FontSize" Value="14" />
                                        <Setter Property="FontFamily" Value="poppinbold" />
                                    </DataTrigger>
                                </Label.Triggers>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectUpcomingCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                    <Border
                        Background="{StaticResource Brush.CardBg}"
                        HorizontalOptions="Center"
                        Shadow="{StaticResource Sh.PurpleLg}"
                        StrokeShape="RoundRectangle 20"
                        StyleClass="pill-secondary"
                        VerticalOptions="Center">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Path
                                Margin="0,0,0,5"
                                Data="M3,11c0,2.45,1.76,4.47,4.08,4.91l-1.49-1.49L7,13l4,4.01L7,21l-1.41-1.41l1.58-1.58l0-0.06C3.7,17.54,1,14.58,1,11c0-3.87,3.13-7,7-7h3v2H8C5.24,6,3,8.24,3,11z M22,11V4h-9v7H22z M20,9h-5V6h5V9z M13,13h9v7h-9z"
                                Fill="{StaticResource Primary}"
                                HeightRequest="25"
                                WidthRequest="25">
                                <Path.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsUpcomingSelected}"
                                        TargetType="Path"
                                        Value="False">
                                        <Setter Property="Fill" Value="{StaticResource Primary}" />
                                        <Setter Property="HeightRequest" Value="25" />
                                        <Setter Property="WidthRequest" Value="25" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding IsUpcomingSelected}"
                                        TargetType="Path"
                                        Value="True">
                                        <Setter Property="HeightRequest" Value="20" />
                                        <Setter Property="WidthRequest" Value="25" />
                                        <Setter Property="Fill" Value="{StaticResource Gray200}" />
                                    </DataTrigger>
                                </Path.Triggers>
                            </Path>
                            <Label
                                Grid.Column="1"
                                StyleClass="pill-secondary-text"
                                Text="Past Orders">
                                <Label.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsUpcomingSelected}"
                                        TargetType="Label"
                                        Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                        <Setter Property="FontFamily" Value="poppinbold" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding IsUpcomingSelected}"
                                        TargetType="Label"
                                        Value="True">
                                        <Setter Property="FontSize" Value="14" />
                                        <Setter Property="TextColor" Value="{StaticResource Gray200}" />
                                        <Setter Property="FontFamily" Value="poppinbold" />
                                    </DataTrigger>
                                </Label.Triggers>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectPastCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                    </Border>


                </HorizontalStackLayout>
            </VerticalStackLayout>
            <Border
                Grid.Row="1"
                Shadow="{StaticResource Sh.PurpleLg}"
                StyleClass="card">
                <ScrollView Margin="5,0,5,0" VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding DisplayedOrders}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Background="{StaticResource Brush.CardBg}"
                                    Stroke="{StaticResource Gray100}"
                                    StrokeShape="RoundRectangle 15"
                                    StrokeThickness="1"
                                    Style="{StaticResource OrderItemCard}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Path=BindingContext.GoToOrderDetailsCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Padding="0,8" Spacing="12">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label
                                                FontFamily="poppinbold"
                                                FontSize="18"
                                                Text="{Binding OrderNumber}"
                                                TextColor="{StaticResource Black}" />
                                            <Label
                                                FontFamily="poppinbold"
                                                FontSize="18"
                                                HorizontalOptions="End"
                                                Text="{Binding TotalPrice}"
                                                TextColor="{StaticResource Primary}" />
                                        </HorizontalStackLayout>
                                        <Label Style="{StaticResource SubtextStyle}" Text="{Binding RestaurantInfo}" />
                                        <HorizontalStackLayout Style="{StaticResource DeliveryRow}">
                                            <Image
                                                Margin="0,0,12,0"
                                                Aspect="AspectFit"
                                                HeightRequest="40"
                                                Source="expressdelivery.png"
                                                WidthRequest="40" />
                                            <VerticalStackLayout VerticalOptions="Center">
                                                <Label
                                                    LineBreakMode="TailTruncation"
                                                    MaxLines="1"
                                                    Style="{StaticResource AddressLabelStyle}"
                                                    Text="{Binding Address}" />
                                                <Label Style="{StaticResource SubtextStyle}" Text="{Binding Status}" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>


        </Grid>

        <!--  Floating Tab Bar  -->
        <controls:FloatingTabBar
            Margin="0,20,0,0"
            AbsoluteLayout.LayoutBounds="0.5,1,1,76"
            AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional"
            ZIndex="1000" />

    </AbsoluteLayout>
</ContentPage>