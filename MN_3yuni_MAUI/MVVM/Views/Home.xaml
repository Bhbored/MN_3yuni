<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MN_3yuni_MAUI.MVVM.Views.Home"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MN_3yuni_MAUI.Controls"
    xmlns:converters="clr-namespace:MN_3yuni_MAUI.Converters"
    xmlns:models="clr-namespace:Shared.Models;assembly=Shared"
    xmlns:vm="clr-namespace:MN_3yuni_MAUI.MVVM.ViewModels"
    x:DataType="vm:HomeVM"
    BackgroundColor="{StaticResource BackgroundGray}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:TransactionStatusToIconConverter x:Key="TransactionStatusIconConverter" />
            <converters:TransactionStatusToColorConverter x:Key="TransactionStatusColorConverter" />
            <converters:TransactionStatusToDescriptionConverter x:Key="TransactionStatusDescriptionConverter" />
            <converters:TransactionStatusTextColorConverter x:Key="TransactionStatusTextColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <AbsoluteLayout>
        <Grid
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            RowDefinitions="Auto,*">

            <!--  ===== Row 0: header with fixed wallet card =====  -->
            <AbsoluteLayout Grid.Row="0" HeightRequest="300">
                <!--  Header background (your paths)  -->
                <Grid AbsoluteLayout.LayoutBounds="0,0,1,1" AbsoluteLayout.LayoutFlags="All">
                    <!--  Big soft gradient wave  -->
                    <Path StrokeThickness="0">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0.0" Color="{StaticResource PrimaryDark}" />
                                <GradientStop Offset="1.0" Color="{StaticResource Primary}" />
                            </LinearGradientBrush>
                        </Path.Fill>
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure IsClosed="True" StartPoint="0,220">
                                    <BezierSegment
                                        Point1="180,160"
                                        Point2="380,120"
                                        Point3="750,40" />
                                    <LineSegment Point="750,0" />
                                    <LineSegment Point="0,0" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!--  Secondary highlight wave  -->
                    <Path Opacity="0.55" StrokeThickness="0">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0.0" Color="{StaticResource PrimaryLight}" />
                                <GradientStop Offset="1.0" Color="{StaticResource Primary}" />
                            </LinearGradientBrush>
                        </Path.Fill>
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure IsClosed="True" StartPoint="0,260">
                                    <BezierSegment
                                        Point1="220,210"
                                        Point2="480,160"
                                        Point3="750,80" />
                                    <LineSegment Point="750,0" />
                                    <LineSegment Point="0,0" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!--  Greeting row  -->
                    <StackLayout Padding="20,48,20,20" VerticalOptions="Start">
                        <HorizontalStackLayout Spacing="12">
                            <Image
                                Aspect="AspectFill"
                                HeightRequest="44"
                                Source="avatar10.png"
                                VerticalOptions="Center"
                                WidthRequest="44" />
                            <VerticalStackLayout Spacing="-2">
                                <Label StyleClass="GreetingStyle" Text="Welcome back," />
                                <Label StyleClass="NameStyle" Text="Ethan!" />
                            </VerticalStackLayout>

                            <Border
                                Margin="120,0,0,0"
                                Stroke="{StaticResource Gray100}"
                                StrokeThickness="3"
                                StyleClass="IconChip">
                                <Image
                                    Aspect="AspectFit"
                                    HeightRequest="22"
                                    HorizontalOptions="Center"
                                    Source="bell.png"
                                    VerticalOptions="Center"
                                    WidthRequest="22" />
                            </Border>
                        </HorizontalStackLayout>
                    </StackLayout>
                </Grid>

                <!--  Wallet card anchored to bottom of header  -->
                <Border
                    AbsoluteLayout.LayoutBounds="0.5,1,0.9,132"
                    AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional"
                    StyleClass="WalletCard"
                    TranslationY="-28">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            StyleClass="BalanceLabelStyle"
                            Text="Available balance" />
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,4,0,0"
                            StyleClass="BalanceAmountStyle"
                            Text="$ 1221.33" />
                        <Image
                            Grid.Row="1"
                            Grid.Column="1"
                            Aspect="AspectFit"
                            HeightRequest="30"
                            HorizontalOptions="End"
                            Source="wallet.png"
                            VerticalOptions="End"
                            WidthRequest="30" />
                    </Grid>
                </Border>
            </AbsoluteLayout>
            <!--  ===== Row 1: content (buttons + recent activity) =====  -->
            <Grid
                Grid.Row="1"
                Margin="0,-14,0,0"
                RowDefinitions="Auto,*">

                <!--  Action buttons  -->
                <Grid
                    Grid.Row="0"
                    Margin="20,0,20,0"
                    ColumnDefinitions="*,*"
                    ColumnSpacing="12">
                    <Button
                        Grid.Column="0"
                        StyleClass="AddOrderButtonStyle"
                        Text="➕ Add Order" />
                    <Button
                        Grid.Column="1"
                        StyleClass="TrackOrderButtonStyle"
                        Text="🌀 Track Order" />
                </Grid>

                <!--  Recent Activity card  -->
                <Border
                    Grid.Row="1"
                    Margin="20,10,20,16"
                    StyleClass="SectionCard">
                    <Grid RowDefinitions="Auto,*">
                        <!--  Header  -->
                        <Grid
                            Grid.Row="0"
                            Margin="4,0,4,8"
                            ColumnDefinitions="*,Auto">
                            <Label StyleClass="SectionTitleStyle" Text="Recent Activity" />
                            <Label
                                Grid.Column="1"
                                StyleClass="ViewAllLinkStyle"
                                Text="View All"
                                VerticalOptions="Center" />
                        </Grid>

                        <!--  Scrollable list  -->
                        <CollectionView
                            Grid.Row="1"
                            ItemsLayout="VerticalList"
                            ItemsSource="{Binding Transactions}"
                            VerticalOptions="Fill"
                            VerticalScrollBarVisibility="Always">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:WalletTransaction">
                                    <Border StyleClass="ActivityItemStyle">
                                        <Grid Padding="14" ColumnDefinitions="Auto,*,Auto">

                                            <!--  Icon circle (uses your color converter + icon converter)  -->
                                            <Border
                                                Grid.Column="0"
                                                BackgroundColor="{Binding Status, Converter={StaticResource TransactionStatusColorConverter}}"
                                                StyleClass="ActivityIconCircle">
                                                <Label
                                                    FontFamily="poppinbold"
                                                    FontSize="18"
                                                    HorizontalOptions="Center"
                                                    Text="{Binding Status, Converter={StaticResource TransactionStatusIconConverter}}"
                                                    TextColor="White"
                                                    VerticalOptions="Center" />
                                            </Border>

                                            <!--  Info  -->
                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Spacing="2"
                                                VerticalOptions="Center">
                                                <Label
                                                    FontFamily="poppinbold"
                                                    FontSize="16"
                                                    Text="{Binding Transaction_Type}"
                                                    TextColor="{StaticResource Black}" />
                                                <Label
                                                    FontFamily="poppin"
                                                    FontSize="12"
                                                    Text="{Binding Status, Converter={StaticResource TransactionStatusDescriptionConverter}}"
                                                    TextColor="#888888" />
                                            </VerticalStackLayout>

                                            <!--  Amount  -->
                                            <Label
                                                Grid.Column="2"
                                                FontFamily="poppinbold"
                                                FontSize="16"
                                                Text="{Binding Amount, StringFormat='{}{0:C}'}"
                                                TextColor="{Binding Status, Converter={StaticResource TransactionStatusTextColorConverter}}"
                                                VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <controls:FloatingTabBar
            Margin="{OnPlatform iOS='0,0,0,24',
            Android='0,0,0,12'}"
            AbsoluteLayout.LayoutBounds="0.5,1,1,76"
            AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional"
            ZIndex="1000" />
    </AbsoluteLayout>

</ContentPage>
