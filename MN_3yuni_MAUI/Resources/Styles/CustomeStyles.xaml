<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">


    <!--  COLORS  -->

    <Color x:Key="PrimaryDark">#6A3DFF</Color>
    <Color x:Key="Primary">#7B4DFF</Color>
    <Color x:Key="PrimaryLight">#BDA8FF</Color>
    <Color x:Key="AccentRed">#FF4D4D</Color>

    <Color x:Key="BackgroundGray">#F5F5F7</Color>
    <Color x:Key="CardWhite">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>


    
    <!--  SHADOWS  -->

    <Shadow
        x:Key="ElevSm"
        Brush="#000000"
        Opacity="0.10"
        Radius="10"
        Offset="0,4" />
    <Shadow
        x:Key="ElevMd"
        Brush="#000000"
        Opacity="0.12"
        Radius="20"
        Offset="0,8" />
    <Shadow
        x:Key="ElevLg"
        Brush="#000000"
        Opacity="0.28"
        Radius="28"
        Offset="0,14" />


    <!--  GRADIENTS  -->

    <LinearGradientBrush x:Key="WalletCardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#6C3BFF" />
        <GradientStop Offset="0.65" Color="#b62ff5" />
        <GradientStop Offset="1" Color="#ce70fa" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WalletCardStrokeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource Gray200}" />
        <GradientStop Offset="1" Color="{StaticResource Gray400}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SectionCardBg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#FFFFFF" />
        <GradientStop Offset="1" Color="#F3EEFF" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SectionCardStroke" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#d478ff" />
        <GradientStop Offset="1" Color="#d478ff" />
    </LinearGradientBrush>

    <!--  Tab label on the floating bar  -->
    <Style Class="TabLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!--#region HomePage-->


    <!--  TYPO STYLES  -->
    <Style Class="GreetingStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryLight}" />
    </Style>

    <Style Class="NameStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource CardWhite}" />
    </Style>

    <Style Class="BalanceLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource CardWhite}" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <Style Class="BalanceAmountStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource CardWhite}" />
    </Style>

    <Style Class="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource Black}" />
    </Style>

    <Style Class="ViewAllLinkStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryDark}" />
    </Style>

    <!--  Circular icon chip (bell)  -->
    <Style Class="IconChip" TargetType="Border">
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 999" />
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FFFFFF22" />
                <GradientStop Offset="1" Color="#FFFFFF10" />
            </LinearGradientBrush>
        </Setter>
        <Setter Property="Stroke" Value="{StaticResource WalletCardStrokeGradient}" />
        <Setter Property="Shadow" Value="{StaticResource ElevSm}" />
        <Setter Property="HorizontalOptions" Value="End" />
        <Setter Property="VerticalOptions" Value="Start" />
    </Style>

    <!--  Wallet card  -->
    <Style Class="WalletCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 26" />
        <Setter Property="Background" Value="{StaticResource WalletCardGradient}" />
        <Setter Property="Stroke" Value="{StaticResource WalletCardStrokeGradient}" />
        <Setter Property="Shadow" Value="{StaticResource ElevLg}" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!--  Section wrapper (Recent Activity)  -->
    <Style Class="SectionCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        <Setter Property="Background" Value="{StaticResource SectionCardBg}" />
        <Setter Property="Stroke" Value="{StaticResource SectionCardStroke}" />
        <Setter Property="Shadow" Value="{StaticResource ElevMd}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!--  Activity list item  -->
    <Style Class="ActivityItemStyle" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Shadow" Value="{StaticResource ElevSm}" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!--  Round icon bg in each row  -->
    <Style Class="ActivityIconCircle" TargetType="Border">
        <Setter Property="WidthRequest" Value="40" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 999" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <!--  Primary ghost card button (Add Order)  -->
    <Style Class="AddOrderButtonStyle" TargetType="Button">
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryDark}" />
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#EEE7FF" />
                <GradientStop Offset="1" Color="#FFFFFF" />
            </LinearGradientBrush>
        </Setter>
        <Setter Property="Shadow" Value="{StaticResource ElevSm}" />
    </Style>

    <!--  Neutral outline button (Track Order)  -->
    <Style Class="TrackOrderButtonStyle" TargetType="Button">
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="TextColor" Value="{StaticResource Black}" />
        <Setter Property="BackgroundColor" Value="#FFFFFF" />
        <Setter Property="BorderColor" Value="#E6E1FF" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="Shadow" Value="{StaticResource ElevSm}" />
    </Style>

    <!--#endregion-->

    <!--#region OrdersPage-->
    <!--  hon ziiiid anwaryoooooo  -->

    <!--  Section Header Style (uppercase) -->
    <Style x:Key="SectionHeaderStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Gray500}" />
        <Setter Property="TextTransform" Value="Uppercase" />
    </Style>

    <!--  Order Item Card -->
    <Style x:Key="OrderItemCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Background" Value="{StaticResource CardWhite}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Shadow" Value="{StaticResource ElevSm}" />
        <Setter Property="Padding" Value="16,2" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!--  Delivery Row -->
    <Style x:Key="DeliveryRow" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="16" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="DeliveryIconCircle" TargetType="Border">
        <Setter Property="WidthRequest" Value="40" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="BackgroundColor" Value="{StaticResource CardWhite}" />

        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 999" />

        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <!--  Address Label -->
    <Style x:Key="AddressLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource Black}" />
    </Style>

    <!--  Subtext (Street/Price/Role) -->
    <Style x:Key="SubtextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinregular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="#666666" />
    </Style>

    <!--  Status Card -->
    <Style x:Key="WhiteCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Background" Value="{StaticResource CardWhite}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Shadow" Value="{StaticResource ElevSm}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!--  Status Icon Circle -->
    <Style x:Key="StatusIconCircle" TargetType="Border" BasedOn="{StaticResource DeliveryIconCircle}" />

    <!--  Status Text Style -->
    <Style x:Key="StatusTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource Black}" />
    </Style>

    <!--  Status Date Style -->
    <Style x:Key="StatusDateStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinregular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="#666666" />
    </Style>

    <!--  Track Order Button -->
   
    <Style x:Key="TrackOrderButtonStyle" TargetType="Button">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource CardWhite}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shadow" Value="{StaticResource ElevSm}" />
        <Setter Property="HeightRequest" Value="32" />
       
        <Setter Property="HorizontalOptions" Value="End" />
    </Style>

    <!--  Driver Card -->
    <Style x:Key="DriverCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Background" Value="{StaticResource CardWhite}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Shadow" Value="{StaticResource ElevSm}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!--  Driver Name Style -->
    <Style x:Key="DriverNameStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource Black}" />
    </Style>

    <!--  Driver Rating Style -->
    <Style x:Key="DriverRatingStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinbold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource AccentRed}" />
    </Style>

    <!--  Driver Review Count -->
    <Style x:Key="DriverReviewCountStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="poppinregular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="#666666" />
    </Style>

    <!--  Icon Button Style (Chat/Call) -->
    <Style x:Key="IconButtonStyle" TargetType="Border">
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        <Setter Property="BackgroundColor" Value="#F5F5F7" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>


    <!--#endregion-->
</ResourceDictionary>
