<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--  Base Colors  -->
    <Color x:Key="PrimaryLight">#F0E6FF</Color>
    <Color x:Key="PrimaryDark">#6A3DFF</Color>
    <Color x:Key="SecondaryLight">#E6F0FF</Color>
    <Color x:Key="AccentRed">#FF4D4D</Color>
    <Color x:Key="AccentGreen">#4DAB4D</Color>
    <Color x:Key="BackgroundGray">#F5F5F7</Color>
    <Color x:Key="CardWhite">#FFFFFF</Color>
    <Color x:Key="PendingColor">#FFE6E6</Color>
    <Color x:Key="CompletedColor">#E6FFE6</Color>
    <Color x:Key="FailedColor">#FFE6E6</Color>
    <Color x:Key="CancelledColor">#FFE6E6</Color>

    <!--  Text Styles  -->
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="poppin" />
    </Style>


    <!--#region HomePage CONTROLLS-->
    <Style Class="GreetingStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryDark}" />
        <Setter Property="FontFamily" Value="poppinbold" />
    </Style>

    <Style Class="NameStyle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="#333333" />
        <Setter Property="FontFamily" Value="poppinbold" />
    </Style>

    <Style Class="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="#333333" />
        <Setter Property="FontFamily" Value="poppinbold" />
    </Style>

    <Style Class="BalanceLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="Opacity" Value="0.8" />
        <Setter Property="FontFamily" Value="poppin" />
    </Style>

    <Style Class="BalanceAmountStyle" TargetType="Label">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="FontFamily" Value="poppinbold" />
    </Style>

    <Style Class="CardNumberStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="Opacity" Value="0.8" />
        <Setter Property="FontFamily" Value="poppin" />
    </Style>

    <!--  Button Styles  -->
    <Style Class="AddOrderButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#F0E6FF" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryDark}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="15" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <Style Class="TrackOrderButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CardWhite}" />
        <Setter Property="TextColor" Value="#333333" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="15" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="BorderColor" Value="#DDDDDD" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <!--  Activity Item Style  -->
    <Style Class="ActivityItemStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardWhite}" />
        <Setter Property="Stroke" Value="#EEEEEE" />
        <Setter Property="StrokeThickness" Value="3" />
        <Setter Property="StrokeShape" Value="RoundRectangle 15" />
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HeightRequest" Value="80" />
    </Style>

    <!--  Section Title with "View All"  -->
    <Style Class="SectionTitleWithLinkStyle" TargetType="StackLayout">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="0" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <Style Class="ViewAllLinkStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PrimaryDark}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!--#endregion-->


</ResourceDictionary>